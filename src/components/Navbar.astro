---
import { Github } from 'lucide-astro';
import AnimatedLogo from './AnimatedLogo.astro';
---

<nav class="navbar">
  <div class="container">
    <div class="nav-content">
      <!-- Logo -->
      <a href="/" class="logo">
        <AnimatedLogo />
        <span class="logo-text">ZenGrid</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="nav-links">
        <a href="/features" class="nav-link">Features</a>
        <a href="/examples" class="nav-link">Examples</a>
        <a href="/docs" class="nav-link">Docs</a>
        <a href="/benchmarks" class="nav-link">Benchmarks</a>
        <a href="https://github.com/zengrid-dev/zengrid" class="nav-link" target="_blank" rel="noopener">
          <Github size={20} strokeWidth={1.5} />
          <span>GitHub</span>
        </a>
      </div>

      <!-- CTA Button -->
      <div class="nav-cta">
        <a href="/docs" class="btn btn-primary">Get Started</a>
      </div>

      <!-- Mobile Menu Button -->
      <button class="mobile-menu-btn" aria-label="Toggle menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(2, 6, 23, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(30, 41, 59, 0.5);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--text-main);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-weight: 500;
    font-size: 0.9375rem;
    color: #94a3b8;
    transition: color 0.2s;
    text-decoration: none;
    line-height: 1.4;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: #f8fafc;
  }

  .nav-link :global(svg) {
    flex-shrink: 0;
  }

  .nav-cta {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: #f8fafc;
    padding: 0.5rem;
  }

  @media (max-width: 968px) {
    .nav-links,
    .nav-cta {
      display: none;
    }

    .mobile-menu-btn {
      display: block;
    }
  }

  @media (min-width: 969px) {
    .nav-links {
      display: flex !important;
    }

    .nav-cta {
      display: flex !important;
    }

    .mobile-menu-btn {
      display: none !important;
    }
  }
</style>
