---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import {
  createBreadcrumbStructuredData,
  createCollectionPageStructuredData,
  type BreadcrumbItem,
} from '../lib/seo';

interface HubItem {
  href: string;
  title: string;
  description: string;
}

interface ActionLink {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary';
}

interface Props {
  title: string;
  description: string;
  pathname: string;
  intro: string;
  items: HubItem[];
  eyebrow?: string;
  keywords?: string[];
  actions?: ActionLink[];
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description,
  pathname,
  intro,
  items,
  eyebrow = 'ZenGrid',
  keywords = [],
  actions = [],
  breadcrumbs = [
    { title: 'Home', path: '/' },
    { title, path: pathname },
  ],
} = Astro.props;

const structuredData = [
  createCollectionPageStructuredData({ title, description, pathname }),
  createBreadcrumbStructuredData(breadcrumbs),
];
---

<BaseLayout
  title={title}
  description={description}
  pathname={pathname}
  keywords={keywords}
  structuredData={structuredData}
>
  <Navbar />

  <section class="hub-hero">
    <div class="container">
      <p class="hub-eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="hub-intro">{intro}</p>

      {actions.length > 0 && (
        <div class="hub-actions">
          {actions.map((action) => (
            <a
              href={action.href}
              class:list={['btn', action.variant === 'secondary' ? 'btn-secondary' : 'btn-primary']}
            >
              {action.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="hub-grid-section">
    <div class="container">
      <div class="hub-grid">
        {items.map((item) => (
          <a href={item.href} class="hub-card">
            <h2>{item.title}</h2>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .hub-hero {
    padding: 4.5rem 0 2.5rem;
  }

  .hub-eyebrow {
    margin-bottom: 0.6rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--zen-primary);
  }

  .hub-intro {
    max-width: 760px;
    margin-top: 1rem;
    font-size: 1.1rem;
  }

  .hub-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1.75rem;
    flex-wrap: wrap;
  }

  .hub-grid-section {
    padding: 1rem 0 4.5rem;
  }

  .hub-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .hub-card {
    display: block;
    min-height: 180px;
    padding: 1.5rem;
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    text-decoration: none;
    background: rgba(15, 23, 42, 0.65);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .hub-card:hover {
    transform: translateY(-2px);
    border-color: rgba(52, 211, 153, 0.5);
    box-shadow: var(--glow-primary);
  }

  .hub-card h2 {
    margin-bottom: 0.75rem;
    font-size: 1.2rem;
  }

  @media (max-width: 980px) {
    .hub-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .hub-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
