---
import DemoContainer from './DemoContainer.astro';
---

<DemoContainer id="basic-demo-grid" height="400px" caption="200 rows with selection enabled">
</DemoContainer>

<script>
  import { Grid } from '@zengrid/core';
  import '@zengrid/core/dist/styles.css';

  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('basic-demo-grid');
    if (!container) return;

    const roles = ['Admin', 'Editor', 'Viewer', 'Manager', 'Developer'];
    const statuses = ['Active', 'Inactive', 'Pending', 'Suspended'];
    const rowCount = 200;

    const data = Array.from({ length: rowCount }, (_, i) => [
      i + 1,
      `User ${i + 1}`,
      `user${i + 1}@example.com`,
      roles[i % roles.length],
      statuses[i % statuses.length],
    ]);

    const columns = [
      { field: 'id', header: 'ID', width: 60 },
      { field: 'name', header: 'Name', width: 180 },
      { field: 'email', header: 'Email', width: 240 },
      { field: 'role', header: 'Role', width: 140 },
      { field: 'status', header: 'Status', width: 120 },
    ];

    const grid = new Grid(container, {
      rowCount,
      colCount: columns.length,
      rowHeight: 32,
      colWidth: columns.map(c => c.width),
      columns,
      enableSelection: true,
    });

    grid.setData(data);
    grid.render();
  });
</script>
