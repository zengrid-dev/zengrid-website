---
const installCmd = 'npm install @zengrid/core';
---

<div class="grid-demo">
  <div class="demo-chrome-bar">
    <div class="mac-buttons">
      <span class="mac-btn red"></span>
      <span class="mac-btn yellow"></span>
      <span class="mac-btn green"></span>
    </div>
    <button class="theme-toggle" id="homepage-theme-toggle" aria-label="Toggle theme">
      <span class="theme-icon theme-icon--light">&#9788;</span>
      <span class="theme-icon theme-icon--dark">&#9790;</span>
    </button>
  </div>
  <div class="demo-preview">
    <div id="grid-container" class="grid-container" aria-label="ZenGrid product preview">
      <div class="grid-fallback" aria-hidden="true">
        <div class="grid-fallback__toolbar">
          <span class="grid-pill grid-pill--active"></span>
          <span class="grid-pill"></span>
          <span class="grid-pill"></span>
        </div>
        <div class="grid-fallback__table">
          <div class="grid-fallback__row grid-fallback__row--header"></div>
          <div class="grid-fallback__row"></div>
          <div class="grid-fallback__row"></div>
          <div class="grid-fallback__row"></div>
          <div class="grid-fallback__row"></div>
          <div class="grid-fallback__row"></div>
        </div>
      </div>
    </div>
    <div class="npm-install">
      <div class="install-label">Install from npm</div>
      <div class="install-command">
        <code id="install-text">{installCmd}</code>
        <button class="copy-btn" id="copy-btn" aria-label="Copy install command">
          <span class="copy-icon">📋</span>
        </button>
      </div>
    </div>
  </div>
  <div class="grid-info">
    <p>⚡ High-performance virtual scrolling • <strong>14 Data Structures</strong> • TypeScript</p>
  </div>
</div>

<script>
  import { initHomepageGridDemo } from '../lib/homepage-grid-demo';

  const startDemo = () => initHomepageGridDemo();

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startDemo, { once: true });
  } else {
    startDemo();
  }

  document.addEventListener('astro:page-load', startDemo);
</script>

<style>
  .grid-demo {
    --grid-fallback-border: rgba(148, 163, 184, 0.16);
    --grid-fallback-fill: rgba(148, 163, 184, 0.12);
    max-width: 100%;
    width: 100%;
    margin: 0 auto;
    padding: 1.5rem;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    box-shadow: 0 20px 60px -15px rgba(0, 0, 0, 0.5),
                0 0 0 1px rgba(255,255,255,0.05);
  }

  .demo-chrome-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .mac-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .theme-toggle {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 6px;
    padding: 0.3rem 0.5rem;
    cursor: pointer;
    color: #94a3b8;
    font-size: 0.9rem;
    line-height: 1;
    transition: all 0.15s;
    display: flex;
    align-items: center;
  }

  .theme-toggle:hover {
    background: rgba(255,255,255,0.14);
    color: #e2e8f0;
  }

  .theme-icon--light { display: none; }
  .theme-icon--dark { display: inline; }

  .theme-toggle.is-light .theme-icon--light { display: inline; }
  .theme-toggle.is-light .theme-icon--dark { display: none; }

  .mac-btn {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .mac-btn.red { background: #ef4444; }
  .mac-btn.yellow { background: #f59e0b; }
  .mac-btn.green { background: #10b981; }

  .demo-preview {
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    overflow: hidden;
    background: rgba(15, 23, 42, 0.9);
  }

  .grid-container {
    position: relative;
    width: 100%;
    height: 400px;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.92)),
      radial-gradient(circle at top right, rgba(16, 185, 129, 0.12), transparent 35%);
  }

  .grid-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 1rem;
    padding: 1rem;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(15, 23, 42, 0.85));
  }

  .grid-fallback__toolbar {
    display: flex;
    gap: 0.5rem;
  }

  .grid-pill {
    width: 72px;
    height: 10px;
    border-radius: 999px;
    background: var(--grid-fallback-fill);
  }

  .grid-pill--active {
    background: rgba(16, 185, 129, 0.28);
  }

  .grid-fallback__table {
    display: grid;
    gap: 0.625rem;
    align-content: start;
  }

  .grid-fallback__row {
    height: 42px;
    border-radius: 10px;
    border: 1px solid var(--grid-fallback-border);
    background:
      linear-gradient(90deg,
        rgba(248, 250, 252, 0.02) 0%,
        rgba(148, 163, 184, 0.16) 18%,
        rgba(248, 250, 252, 0.02) 36%),
      rgba(15, 23, 42, 0.72);
    background-size: 220px 100%;
    animation: gridFallbackSweep 2.6s linear infinite;
  }

  .grid-fallback__row--header {
    height: 32px;
    background:
      linear-gradient(90deg,
        rgba(16, 185, 129, 0.04) 0%,
        rgba(16, 185, 129, 0.18) 20%,
        rgba(16, 185, 129, 0.04) 40%),
      rgba(15, 23, 42, 0.92);
  }

  .grid-demo[data-demo-ready='true'] .grid-fallback {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease-out;
  }

  @keyframes gridFallbackSweep {
    from {
      background-position: 220px 0;
    }
    to {
      background-position: -220px 0;
    }
  }

  .grid-container :global(.zg-scroll-container) {
    scrollbar-width: none;
  }

  .grid-container :global(.zg-scroll-container)::-webkit-scrollbar {
    display: none;
  }

  .npm-install {
    padding: 1.5rem;
    background: rgba(16, 185, 129, 0.05);
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .install-label {
    font-size: 0.75rem;
    color: #64748b;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .install-command {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(16, 185, 129, 0.3);
    border-radius: 6px;
    padding: 0.75rem 1rem;
  }

  #install-text {
    font-family: 'Fira Code', 'Monaco', 'Consolas', monospace;
    font-size: 0.875rem;
    color: #10b981;
    flex: 1;
  }

  .copy-btn {
    background: transparent;
    border: none;
    color: #64748b;
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    transition: all 0.2s;
    font-size: 1.25rem;
  }

  .copy-btn:hover {
    color: #10b981;
    transform: scale(1.1);
  }

  .grid-info {
    margin-top: 1rem;
    text-align: center;
    color: #64748b;
    font-size: 0.8rem;
  }

  .grid-info strong {
    color: #10b981;
  }

  @media (max-width: 768px) {
    .grid-demo { padding: 1rem; }
    .code-example { padding: 1rem; }
    pre { font-size: 0.75rem; }
  }

  @media (max-width: 959px) {
    .theme-toggle {
      display: none;
    }
  }
</style>
