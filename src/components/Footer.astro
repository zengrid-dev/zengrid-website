---
import { Github, Twitter } from 'lucide-astro';

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <!-- Brand Column -->
      <div class="footer-column">
        <div class="footer-logo">
          <img src="/zengrid-final-dark.svg" alt="ZenGrid" class="footer-logo-svg" width="122" height="36" />
        </div>
        <p class="footer-tagline">
          Performance-first virtual grid for the web
        </p>
        <div class="social-links">
          <a href="https://github.com/zengrid-dev/zengrid" target="_blank" rel="noopener" aria-label="GitHub">
            <Github size={24} strokeWidth={1.5} />
          </a>
          <a href="https://x.com/Zengrid_dev" target="_blank" rel="noopener" aria-label="X">
            <Twitter size={24} strokeWidth={1.5} />
          </a>
        </div>
      </div>

      <!-- Product Column -->
      <div class="footer-column">
        <h4 class="footer-heading">Product</h4>
        <ul class="footer-links">
          <li><a href="/features">Features</a></li>
          <li><a href="/examples">Examples</a></li>
          <li><a href="/performance">Performance</a></li>
          <li><a href="/plugins">Plugins</a></li>
        </ul>
      </div>

      <!-- Developers Column -->
      <div class="footer-column">
        <h4 class="footer-heading">Developers</h4>
        <ul class="footer-links">
          <li><a href="/docs">Documentation</a></li>
          <li><a href="/api">API Reference</a></li>
          <li><a href="/docs/getting-started">Getting Started</a></li>
          <li><a href="https://github.com/zengrid-dev/zengrid">GitHub</a></li>
        </ul>
      </div>

      <!-- Community Column -->
      <div class="footer-column">
        <h4 class="footer-heading">Community</h4>
        <ul class="footer-links">
          <li><a href="/">About ZenGrid</a></li>
          <li><a href="https://x.com/Zengrid_dev" target="_blank" rel="noopener">X</a></li>
          <li><a href="mailto:hello@zengrid.dev">Contact</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="copyright">
        © {currentYear} ZenGrid. Open source under MIT License.
      </p>
      <div class="footer-bottom-links">
        <a href="https://github.com/zengrid-dev/zengrid/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a>
        <a href="mailto:hello@zengrid.dev">Contact</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #020617; /* Slate 950 manually or var(--bg-dark) */
    color: var(--text-muted);
    padding: 4rem 0 2rem;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    margin-bottom: 1rem;
  }

  .footer-logo-svg {
    height: 36px;
    width: auto;
    opacity: 0.9;
  }

  .footer-tagline {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    max-width: 300px;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .social-links a:hover {
    color: var(--zen-primary);
  }

  .footer-heading {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-main);
    margin-bottom: 1rem;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--zen-primary);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    border-top: 1px solid var(--border-subtle);
  }

  .copyright {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .footer-bottom-links {
    display: flex;
    gap: 2rem;
  }

  .footer-bottom-links a {
    color: var(--text-muted);
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .footer-bottom-links a:hover {
    color: var(--zen-primary);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
