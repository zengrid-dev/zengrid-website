<style>
  .framework-badges {
    text-align: center;
    margin: 2rem 0 0 0;
  }

  .badges-label {
    color: var(--text-muted);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .badges {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s ease;
    cursor: default;
    position: relative;
  }

  .badge.active {
    filter: grayscale(0%);
    opacity: 1;
  }

  .badge.coming-soon {
    filter: grayscale(100%);
    opacity: 0.4;
  }

  .badge.beta {
    filter: grayscale(0%);
    opacity: 0.85;
  }

  .badge.active:hover,
  .badge.beta:hover {
    transform: translateY(-3px);
  }

  .badge svg {
    width: 40px;
    height: 40px;
    display: block;
  }

  .badge > span:first-of-type {
    font-size: 0.6875rem;
    color: var(--text-dim);
    font-weight: 500;
    line-height: 1.2;
  }

  .badge.active > span:first-of-type {
    color: var(--text-main);
  }

  .badge.beta > span:first-of-type {
    color: var(--text-main);
  }

  .status {
    font-size: 0.625rem;
    padding: 0.125rem 0.5rem;
    border-radius: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }

  .badge.active .status {
    background: rgba(16, 185, 129, 0.2);
    color: var(--zen-primary);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .badge.coming-soon .status {
    background: rgba(100, 116, 139, 0.1);
    color: var(--text-dim);
    border: 1px solid rgba(100, 116, 139, 0.2);
  }

  .badge.beta .status {
    background: rgba(245, 158, 11, 0.14);
    color: #fbbf24;
    border: 1px solid rgba(245, 158, 11, 0.25);
  }
</style>
