---
import '../styles/global.css';
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_TITLE,
  SITE,
  type StructuredData,
  toAbsoluteUrl,
} from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  keywords?: string[];
  noindex?: boolean;
  ogType?: 'website' | 'article';
  structuredData?: StructuredData | StructuredData[];
}

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  pathname = Astro.url.pathname,
  keywords = [],
  noindex = false,
  ogType = 'website',
  structuredData,
} = Astro.props;

const canonicalUrl = toAbsoluteUrl(pathname);
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
const keywordsContent = keywords.length > 0 ? [...new Set(keywords)].join(', ') : undefined;
const structuredDataJson = structuredData ? JSON.stringify(structuredData) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      const scheduleAfterLoad = (task) => {
        const idleCallback = window.requestIdleCallback;
        if (idleCallback) {
          window.addEventListener('load', () => idleCallback(task, { timeout: 3000 }), { once: true });
          return;
        }

        window.addEventListener('load', () => window.setTimeout(task, 1500), { once: true });
      };

      scheduleAfterLoad(() => {
        if (window.__zenAnalyticsLoaded) return;
        window.__zenAnalyticsLoaded = true;

        window.dataLayer = window.dataLayer || [];
        window.gtag = function () { window.dataLayer.push(arguments); };
        window.gtag('js', new Date());
        window.gtag('config', 'AW-18054799964');

        const gtagScript = document.createElement('script');
        gtagScript.async = true;
        gtagScript.src = 'https://www.googletagmanager.com/gtag/js?id=AW-18054799964';
        document.head.appendChild(gtagScript);

        const beaconScript = document.createElement('script');
        beaconScript.defer = true;
        beaconScript.src = 'https://static.cloudflareinsights.com/beacon.min.js';
        beaconScript.setAttribute('data-cf-beacon', '{"token":"93885e248e654b94952498996d47649c"}');
        document.head.appendChild(beaconScript);
      });
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content={SITE.name} />
    <meta name="generator" content={Astro.generator} />
    {keywordsContent && <meta name="keywords" content={keywordsContent} />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Social -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="ZenGrid" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content={SITE.twitter} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {structuredDataJson && (
      <script type="application/ld+json" set:html={structuredDataJson}></script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  body {
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  code,
  pre {
    font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
  }
</style>
