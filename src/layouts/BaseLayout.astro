---
import '../styles/global.css';
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_TITLE,
  SITE,
  type StructuredData,
  toAbsoluteUrl,
} from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  keywords?: string[];
  noindex?: boolean;
  ogType?: 'website' | 'article';
  structuredData?: StructuredData | StructuredData[];
}

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  pathname = Astro.url.pathname,
  keywords = [],
  noindex = false,
  ogType = 'website',
  structuredData,
} = Astro.props;

const canonicalUrl = toAbsoluteUrl(pathname);
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
const keywordsContent = keywords.length > 0 ? [...new Set(keywords)].join(', ') : undefined;
const structuredDataJson = structuredData ? JSON.stringify(structuredData) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18054799964"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-18054799964');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content={SITE.name} />
    <meta name="generator" content={Astro.generator} />
    {keywordsContent && <meta name="keywords" content={keywordsContent} />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Social -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="ZenGrid" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content={SITE.twitter} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload fonts for better performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Cloudflare Web Analytics -->
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token":"93885e248e654b94952498996d47649c"}'
    ></script>

    {structuredDataJson && (
      <script type="application/ld+json" set:html={structuredDataJson}></script>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  code,
  pre {
    font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
  }
</style>
