---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/docs/Sidebar.astro';
import '../../styles/docs.css';
import { sidebar } from '../../config/sidebar';
import { createDocsStructuredData } from '../../lib/seo';

const structuredData = createDocsStructuredData();
---

<BaseLayout
  title="ZenGrid Documentation | Guides, API Reference, and Examples"
  description="ZenGrid documentation with installation guides, API reference, performance tuning, plugins, and interactive examples."
  pathname="/docs"
  keywords={['ZenGrid docs', 'TypeScript data grid docs', 'JavaScript grid examples', 'virtual grid API']}
  structuredData={structuredData}
>
  <nav class="navbar">
    <div class="container">
      <div class="nav-content">
        <a href="/" class="logo">
          <span class="logo-text">ZenGrid</span>
        </a>
        <div class="nav-links">
          <a href="/docs" class="nav-link active-link">Docs</a>
          <a href="https://github.com/zengrid-dev/zengrid" class="nav-link" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </div>
  </nav>

  <div class="docs-layout">
    <Sidebar currentSlug="" />

    <main class="docs-content">
      <div class="docs-landing">
        <h1 class="docs-landing-title">Documentation</h1>
        <p class="docs-landing-desc">
          Everything you need to build high-performance data grids with ZenGrid.
          From quick start guides to advanced plugin development.
        </p>

        <div class="docs-category-grid">
          {sidebar.map((section) => (
            <a href={`/docs/${section.slug}`} class="docs-category-card">
              <h3>{section.title}</h3>
              <p>{section.description || `${section.items.length} articles`}</p>
            </a>
          ))}
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(2, 6, 23, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(30, 41, 59, 0.5);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 0;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--text-main);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-link {
    font-weight: 500;
    font-size: 0.875rem;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-link:hover,
  .active-link {
    color: #f8fafc;
  }
</style>
