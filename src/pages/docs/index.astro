---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/docs/Sidebar.astro';
import '../../styles/docs.css';
import { sidebar } from '../../config/sidebar';

const categoryDescriptions: Record<string, string> = {
  'Getting Started': 'Install ZenGrid and create your first high-performance grid.',
  'User Guide': 'Learn how to load data, configure virtual scrolling, and optimize performance.',
  'Features': 'Selection, sorting, filtering, editing, pagination, and more.',
  'API Reference': 'Complete API documentation for the Grid class, options, events, and types.',
  'Plugins': 'Extend ZenGrid with built-in and custom plugins.',
  'Rendering': 'Customize cell and header rendering with built-in and custom renderers.',
  'Cell Editors': 'Built-in editors for text, numbers, dates, dropdowns, and more.',
  'Examples': 'Interactive examples showing ZenGrid in action.',
  'Advanced': 'Deep dives into the reactive system, plugin architecture, and accessibility.',
};
---

<BaseLayout title="Documentation - ZenGrid" description="ZenGrid documentation — guides, API reference, and examples.">
  <nav class="navbar">
    <div class="container">
      <div class="nav-content">
        <a href="/" class="logo">
          <span class="logo-text">ZenGrid</span>
        </a>
        <div class="nav-links">
          <a href="/docs" class="nav-link active-link">Docs</a>
          <a href="https://github.com/zengrid-dev/zengrid" class="nav-link" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </div>
  </nav>

  <div class="docs-layout">
    <Sidebar currentSlug="" />

    <main class="docs-content">
      <div class="docs-landing">
        <h1 class="docs-landing-title">Documentation</h1>
        <p class="docs-landing-desc">
          Everything you need to build high-performance data grids with ZenGrid.
          From quick start guides to advanced plugin development.
        </p>

        <div class="docs-category-grid">
          {sidebar.map((section) => (
            <a href={`/docs/${section.items[0].slug}`} class="docs-category-card">
              <h3>{section.title}</h3>
              <p>{categoryDescriptions[section.title] || `${section.items.length} articles`}</p>
            </a>
          ))}
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(2, 6, 23, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(30, 41, 59, 0.5);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 0;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--text-main);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-link {
    font-weight: 500;
    font-size: 0.875rem;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-link:hover,
  .active-link {
    color: #f8fafc;
  }
</style>
